---
# Bazujemy na oficjalnym, czystym standardzie LLVM/Microsoft
BasedOnStyle: Microsoft

# Ujednolicenie wcięć (Rozmiar tabulacji i wcięcia na 4 spacje)
TabWidth: 4
IndentWidth: 4
UseTab: Never # Zamienia tabulatory na spacje (bardzo polecane dla spójności)

# Konstrukcje: Gdzie mają być klamry {}
# Allman oznacza, że klamry dla klas, funkcji i "if-ów" zawsze lądują w nowej linii
BreakBeforeBraces: Allman

# Konstrukcje: Spacje wokół operatorów i nawiasów
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements # spacja po 'if', 'while', 'switch'
SpaceInEmptyParentheses: false
SpacesInAngles: false # brak spacji w <vector>

# Konstrukcje: Automatyczne wyrównywanie gwiazdek/referencji przy typach
PointerAlignment: Left # Zapisuje jako 'const Board& board' a nie 'Board &board'

# Maksymalna długość linii kodu zanim formater sam ją zawinie
ColumnLimit: 100
...